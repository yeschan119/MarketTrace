# LLM provider for event extraction: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=
# Optional: override the extraction model. Defaults to a per-provider model
# (anthropic -> claude-sonnet-4-6, openai -> gpt-4o) when left unset.
EXTRACTION_MODEL=
DATABASE_URL=postgresql+psycopg://markettrace:markettrace@localhost:5432/markettrace
SEC_USER_AGENT="MarketTrace dev youremail@example.com"
OBJECT_STORE_DIR=./_objectstore
# US price data backend: "tiingo" (default) or "stooq"
PRICE_PROVIDER=tiingo
# Required when PRICE_PROVIDER=tiingo (free key at https://www.tiingo.com)
TIINGO_API_KEY=
# Optional: FRED/ALFRED macro data for the surprise feature (free key at
# https://fred.stlouisfed.org/docs/api/api_key.html). Macro ingest is skipped
# when unset.
FRED_API_KEY=
# Comma-separated FRED series ingested by markettrace-macro (default shown)
MACRO_SERIES=CPIAUCSL,UNRATE,FEDFUNDS,DGS10
# Comma-separated origins allowed by CORS (the deployed web URL in production)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional local card statement folder for the login-gated ledger view.
# CARD_STATEMENT_PASSWORD may be left unset; the web page can submit it per request.
CARD_STATEMENT_DIR=../card_statement
CARD_STATEMENT_PASSWORD=
